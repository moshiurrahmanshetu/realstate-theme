{
    "$schema": "https://schemas.wp.org/trunk/theme.json",
    "version": 2,
    "title": "Nextoolify Real Estate",
    "settings": {
        "layout": {
            "contentSize": "1200px",
            "wideSize": "1400px"
        },
        "color": {
            "palette": [
                {
                    "slug": "primary",
                    "color": "#2c3e50",
                    "name": "Primary"
                },
                {
                    "slug": "secondary",
                    "color": "#3498db",
                    "name": "Secondary"
                },
                {
                    "slug": "accent",
                    "color": "#e74c3c",
                    "name": "Accent"
                },
                {
                    "slug": "success",
                    "color": "#27ae60",
                    "name": "Success"
                },
                {
                    "slug": "warning",
                    "color": "#f39c12",
                    "name": "Warning"
                },
                {
                    "slug": "light",
                    "color": "#ecf0f1",
                    "name": "Light"
                },
                {
                    "slug": "dark",
                    "color": "#2c3e50",
                    "name": "Dark"
                },
                {
                    "slug": "white",
                    "color": "#ffffff",
                    "name": "White"
                }
            ],
            "duotone": [
                {
                    "slug": "default-grayscale",
                    "colors": [ "#000000", "#ffffff" ],
                    "name": "Default Grayscale"
                },
                {
                    "slug": "primary-grayscale",
                    "colors": [ "#2c3e50", "#ffffff" ],
                    "name": "Primary Grayscale"
                },
                {
                    "slug": "secondary-grayscale",
                    "colors": [ "#3498db", "#ffffff" ],
                    "name": "Secondary Grayscale"
                }
            ],
            "background": "#ffffff",
            "text": "#333333",
            "link": "#3498db",
            "custom": true,
            "customGradient": true
        },
        "typography": {
            "fontSizes": [
                {
                    "slug": "extra-small",
                    "size": "12px",
                    "name": "Extra Small"
                },
                {
                    "slug": "small",
                    "size": "14px",
                    "name": "Small"
                },
                {
                    "slug": "normal",
                    "size": "16px",
                    "name": "Normal"
                },
                {
                    "slug": "medium",
                    "size": "18px",
                    "name": "Medium"
                },
                {
                    "slug": "large",
                    "size": "24px",
                    "name": "Large"
                },
                {
                    "slug": "extra-large",
                    "size": "32px",
                    "name": "Extra Large"
                },
                {
                    "slug": "huge",
                    "size": "48px",
                    "name": "Huge"
                },
                {
                    "slug": "gigantic",
                    "size": "64px",
                    "name": "Gigantic"
                }
            ],
            "fontFamilies": [
                {
                    "fontFamily": "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen-Sans, Ubuntu, Cantarell, 'Helvetica Neue', sans-serif",
                    "slug": "system-font",
                    "name": "System Font"
                },
                {
                    "fontFamily": "'Playfair Display', Georgia, serif",
                    "slug": "playfair-display",
                    "name": "Playfair Display"
                },
                {
                    "fontFamily": "'Open Sans', sans-serif",
                    "slug": "open-sans",
                    "name": "Open Sans"
                },
                {
                    "fontFamily": "'Lato', sans-serif",
                    "slug": "lato",
                    "name": "Lato"
                }
            ],
            "lineHeight": true,
            "textDecoration": true,
            "textTransform": true,
            "letterSpacing": true,
            "writingMode": true,
            "fontStyle": true,
            "fontWeight": true
        },
        "spacing": {
            "units": [
                "px",
                "em",
                "rem",
                "vh",
                "vw",
                "%"
            ],
            "spacingSizes": [
                {
                    "slug": "extra-tiny",
                    "size": "4px",
                    "name": "Extra Tiny"
                },
                {
                    "slug": "tiny",
                    "size": "8px",
                    "name": "Tiny"
                },
                {
                    "slug": "small",
                    "size": "16px",
                    "name": "Small"
                },
                {
                    "slug": "medium",
                    "size": "24px",
                    "name": "Medium"
                },
                {
                    "slug": "large",
                    "size": "32px",
                    "name": "Large"
                },
                {
                    "slug": "extra-large",
                    "size": "48px",
                    "name": "Extra Large"
                },
                {
                    "slug": "huge",
                    "size": "64px",
                    "name": "Huge"
                },
                {
                    "slug": "gigantic",
                    "size": "96px",
                    "name": "Gigantic"
                }
            ],
            "margin": true,
            "padding": true,
            "blockGap": true
        },
        "border": {
            "radius": true,
            "color": true,
            "style": true,
            "width": true
        },
        "shadow": {
            "presets": [
                {
                    "slug": "small",
                    "name": "Small",
                    "shadow": "0 1px 2px 0 rgba(0, 0, 0, 0.05)"
                },
                {
                    "slug": "medium",
                    "name": "Medium",
                    "shadow": "0 4px 6px -1px rgba(0, 0, 0, 0.1)"
                },
                {
                    "slug": "large",
                    "name": "Large",
                    "shadow": "0 10px 15px -3px rgba(0, 0, 0, 0.1)"
                }
            ]
        },
        "blocks": {
            "core/button": {
                "border": {
                    "radius": true,
                    "color": true,
                    "style": true,
                    "width": true
                },
                "color": {
                    "text": true,
                    "background": true,
                    "gradient": true
                },
                "spacing": {
                    "padding": true,
                    "margin": true
                },
                "typography": {
                    "fontSize": true,
                    "fontFamily": true,
                    "fontWeight": true,
                    "letterSpacing": true,
                    "textTransform": true
                }
            },
            "core/group": {
                "border": {
                    "radius": true,
                    "color": true,
                    "style": true,
                    "width": true
                },
                "color": {
                    "text": true,
                    "background": true,
                    "gradient": true
                },
                "spacing": {
                    "padding": true,
                    "margin": true,
                    "blockGap": true
                }
            },
            "core/quote": {
                "border": {
                    "radius": true,
                    "color": true,
                    "style": true,
                    "width": true
                },
                "color": {
                    "text": true,
                    "background": true
                },
                "typography": {
                    "fontSize": true,
                    "fontStyle": true,
                    "fontWeight": true
                }
            },
            "core/columns": {
                "spacing": {
                    "blockGap": true
                }
            },
            "core/cover": {
                "spacing": {
                    "padding": true,
                    "margin": true
                },
                "color": {
                    "text": true,
                    "background": true,
                    "overlay": true
                }
            },
            "core/heading": {
                "typography": {
                    "fontSize": true,
                    "fontFamily": true,
                    "fontWeight": true,
                    "lineHeight": true,
                    "textTransform": true
                },
                "color": {
                    "text": true
                }
            },
            "core/paragraph": {
                "typography": {
                    "fontSize": true,
                    "fontFamily": true,
                    "lineHeight": true,
                    "letterSpacing": true
                },
                "color": {
                    "text": true
                },
                "spacing": {
                    "margin": true
                }
            },
            "core/image": {
                "spacing": {
                    "margin": true
                },
                "border": {
                    "radius": true,
                    "color": true,
                    "style": true,
                    "width": true
                }
            },
            "core/post-title": {
                "typography": {
                    "fontSize": true,
                    "fontFamily": true,
                    "fontWeight": true,
                    "lineHeight": true
                },
                "color": {
                    "text": true
                }
            },
            "core/post-content": {
                "typography": {
                    "fontSize": true,
                    "fontFamily": true,
                    "lineHeight": true
                },
                "spacing": {
                    "margin": true
                }
            }
        }
    },
    "styles": {
        "color": {
            "background": "#ffffff",
            "text": "#333333",
            "link": "#3498db"
        },
        "typography": {
            "fontFamily": "var(--wp--preset--font-family--system-font)",
            "fontSize": "var(--wp--preset--font-size--normal)",
            "lineHeight": "1.6"
        },
        "spacing": {
            "blockGap": "24px"
        },
        "blocks": {
            "core/button": {
                "border": {
                    "radius": "4px"
                },
                "color": {
                    "background": "var(--wp--preset--color--primary)",
                    "text": "#ffffff"
                },
                "spacing": {
                    "padding": "12px 24px"
                },
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--medium)",
                    "fontWeight": "600"
                }
            },
            "core/quote": {
                "border": {
                    "width": "4px",
                    "style": "solid",
                    "color": "var(--wp--preset--color--secondary)"
                },
                "spacing": {
                    "padding": "24px",
                    "margin": "24px 0"
                },
                "typography": {
                    "fontStyle": "italic",
                    "fontSize": "var(--wp--preset--font-size--large)"
                }
            },
            "core/heading": {
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--playfair-display)",
                    "fontWeight": "700"
                },
                "spacing": {
                    "margin": {
                        "top": "0",
                        "bottom": "16px"
                    }
                }
            },
            "core/paragraph": {
                "spacing": {
                    "margin": {
                        "top": "0",
                        "bottom": "16px"
                    }
                }
            },
            "core/image": {
                "border": {
                    "radius": "4px"
                }
            }
        },
        "elements": {
            "h1": {
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--playfair-display)",
                    "fontSize": "var(--wp--preset--font-size--gigantic)",
                    "lineHeight": "1.2",
                    "fontWeight": "700"
                },
                "spacing": {
                    "margin": {
                        "top": "0",
                        "bottom": "24px"
                    }
                }
            },
            "h2": {
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--playfair-display)",
                    "fontSize": "var(--wp--preset--font-size--huge)",
                    "lineHeight": "1.3",
                    "fontWeight": "700"
                },
                "spacing": {
                    "margin": {
                        "top": "0",
                        "bottom": "20px"
                    }
                }
            },
            "h3": {
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--playfair-display)",
                    "fontSize": "var(--wp--preset--font-size--extra-large)",
                    "lineHeight": "1.4",
                    "fontWeight": "700"
                },
                "spacing": {
                    "margin": {
                        "top": "0",
                        "bottom": "18px"
                    }
                }
            },
            "h4": {
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--playfair-display)",
                    "fontSize": "var(--wp--preset--font-size--large)",
                    "lineHeight": "1.5",
                    "fontWeight": "700"
                },
                "spacing": {
                    "margin": {
                        "top": "0",
                        "bottom": "16px"
                    }
                }
            },
            "h5": {
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--playfair-display)",
                    "fontSize": "var(--wp--preset--font-size--medium)",
                    "lineHeight": "1.5",
                    "fontWeight": "600"
                },
                "spacing": {
                    "margin": {
                        "top": "0",
                        "bottom": "14px"
                    }
                }
            },
            "h6": {
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--playfair-display)",
                    "fontSize": "var(--wp--preset--font-size--normal)",
                    "lineHeight": "1.5",
                    "fontWeight": "600"
                },
                "spacing": {
                    "margin": {
                        "top": "0",
                        "bottom": "12px"
                    }
                }
            },
            "a": {
                "color": {
                    "text": "var(--wp--preset--color--secondary)"
                },
                "typography": {
                    "textDecoration": "none"
                }
            },
            "button": {
                "color": {
                    "background": "var(--wp--preset--color--primary)",
                    "text": "#ffffff"
                },
                "border": {
                    "radius": "4px"
                },
                "spacing": {
                    "padding": "12px 24px"
                }
            }
        }
    },
    "customTemplates": {
        "page": {
            "postTypes": [
                "page"
            ],
            "title": "Page"
        },
        "single": {
            "postTypes": [
                "post"
            ],
            "title": "Single Post"
        }
    },
    "templateParts": {
        "header": {
            "area": "header",
            "title": "Header"
        },
        "footer": {
            "area": "footer",
            "title": "Footer"
        },
        "sidebar": {
            "area": "sidebar",
            "title": "Sidebar"
        }
    }
}
